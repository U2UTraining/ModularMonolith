<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <RootNamespace>ModularMonolith.APIs.Tests</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\ModularMonolith.APIs\ModularMonolith.APIs.csproj" />
    <ProjectReference Include="..\..\src\ModularMonolith.MigrationService\ModularMonolith.MigrationService.csproj" />
  </ItemGroup>
  
  <!-- Testing Frameworks -->
  <ItemGroup>
    <PackageReference Include="TUnit" />
  </ItemGroup>
  
  <!-- Stubbing and Mocking -->
  <ItemGroup>
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="NSubstitute.Analyzers.CSharp">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  
  <!-- Test Containers -->
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
    <PackageReference Include="Testcontainers.MsSql" />
  </ItemGroup>

  <!-- Global Using Directives -->
  <ItemGroup>
    <Using Include="TUnit" />
    <Using Include="TUnit.Assertions" />
    <Using Include="NSubstitute" />
    <Using Include="Testcontainers.MsSql" />
    <Using Include="Microsoft.EntityFrameworkCore" />
  </ItemGroup>

</Project>
