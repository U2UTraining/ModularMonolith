<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <base href="/" />
  <ResourcePreloader />
  <link rel="stylesheet" href="@Assets["app.css"]" />
  <link rel="stylesheet" href="@Assets["ModularMonolith.BlazorApp.styles.css"]" />
  <ImportMap />
  <HeadOutlet />
</head>

<body>
  <FluentDesignTheme StorageName="theme" />
  <Routes @rendermode="renderMode" />
  <ReconnectModal />
  <script src="@Assets["_framework/blazor.web.js"]"></script>
  <script src="_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js" type="text/javascript"></script>
  <loading-theme storage-name="theme"></loading-theme>
  <script>
    window.registerForSse = (caller) =>
    {
      const source = new EventSource('https://localhost:7248/integration-events');
      source.addEventListener('integrationEvent', function (event) {
        let data = JSON.parse(event.data);
        caller.invokeMethodAsync('ProcessEvent', data.data, data.eventType);
      });
      return source;
    }

    window.unregisterForSse = (source) =>
    {
      console.log('unregistering');
      source.close();
    }
  </script>
</body>
</html>

@code {
  readonly IComponentRenderMode renderMode =
        new InteractiveServerRenderMode(prerender: false);
}
