@page "/settings"
@using System.Globalization
@using Microsoft.AspNetCore.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Extensions
@inject IOptions<RequestLocalizationOptions> LocalizationOptions
@inject NavigationManager NavigationManager

<h3>Settings</h3>

<FluentDesignTheme @bind-Mode="@Mode" @bind-OfficeColor="@OfficeColor" StorageName="theme" />

<div style="min-height: 250px;">
  <FluentGrid>
    <FluentGridItem>
      <FluentSelect Label="Theme"
                    Width="250px"
                    Items="@(Enum.GetValues<DesignThemeModes>())"
                    @bind-SelectedOption="@Mode" />
    </FluentGridItem>

    <FluentGridItem>
      <FluentSelect Label="Color"
                    Items="@(Enum.GetValues<OfficeColor>().Select(i => (OfficeColor?)i))"
                    Height="200px"
                    Width="250px"
                    @bind-SelectedOption="@OfficeColor">
        <OptionTemplate>
          <FluentStack>
            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20.RectangleLandscape())"
                        Color="Color.Custom"
                        CustomColor="@(@context.ToAttributeValue() != "default" ? context.ToAttributeValue() : "#036ac4" )" />
            <FluentLabel>@context</FluentLabel>
          </FluentStack>
        </OptionTemplate>
      </FluentSelect>
      <FluentButton Appearance="Appearance.Accent" OnClick="PickRandomColor">Feeling lucky?</FluentButton>
    </FluentGridItem>

    <FluentGridItem>
      <FluentSelect Label="Language / Region"
                    Width="250px"
                    Items="@supportedCultures"
                    OptionValue="@(c => c?.Name ?? string.Empty)"
                    OptionText="@(c => c is not null ? $"{c.NativeName} ({c.Name})" : string.Empty)"
                    Height="200px"
                    @bind-SelectedOption="@selectedCulture"
                    @bind-SelectedOption:after="OnCultureChanged" />
    </FluentGridItem>
  </FluentGrid>
</div>

@code
{
  public DesignThemeModes Mode { get; set; }

  public OfficeColor? OfficeColor { get; set; }

  private List<CultureInfo> supportedCultures = [];
  private CultureInfo? selectedCulture;

  protected override void OnInitialized()
  {
    supportedCultures = LocalizationOptions.Value.SupportedCultures?
      .OrderBy(c => c.NativeName)
      .ToList() ?? [];

    selectedCulture = supportedCultures
      .FirstOrDefault(c => c.Name == CultureInfo.CurrentCulture.Name)
      ?? supportedCultures.FirstOrDefault();
  }

  private void OnCultureChanged()
  {
    if (selectedCulture is null || selectedCulture.Name == CultureInfo.CurrentCulture.Name)
    {
      return;
    }

    // Navigate to the culture-setting endpoint, which sets the cookie and redirects back
    string redirectUri = new Uri(NavigationManager.Uri).PathAndQuery;
    NavigationManager.NavigateTo(
      $"/culture/set?culture={Uri.EscapeDataString(selectedCulture.Name)}&redirectUri={Uri.EscapeDataString(redirectUri)}",
      forceLoad: true);
  }

  private void PickRandomColor()
  {
    OfficeColor = OfficeColorUtilities.GetRandom();
  }
}
